# Copy to .dev/local.env (gitignored). Optional catch-all for secrets and overrides.
# dev.sh and openatlas-ingest load this after .env. Feed keys can also live in
# .dev/feed-secrets.json (preferred for Settings UI).

# Ingest admin (optional) — require x-openatlas-key header on sensitive routes
# OPENATLAS_API_KEY=

# Feed API keys (alternative to feed-secrets.json; file wins on ingest start)
# FRED_API_KEY=
# EIA_API_KEY=

# SpacetimeDB target (defaults match ./dev.sh)
# OPENATLAS_STDB_URI=http://127.0.0.1:3000
# OPENATLAS_STDB_DB=openatlas

# Ingest mode: sim | live | hybrid | static
# OPENATLAS_INGEST_MODE=hybrid
