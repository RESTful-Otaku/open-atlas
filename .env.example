# Copy to .env (gitignored):  cp .env.example .env
# Or run:  ./scripts/init-local-config.sh
# Full layout: docs/CONFIG.md

# Ingest: sim | live | hybrid | static  (./dev.sh up defaults to hybrid)
OPENATLAS_INGEST_MODE=hybrid

# SpacetimeDB (ingest + CLI)
OPENATLAS_STDB_URI=http://127.0.0.1:3000
OPENATLAS_STDB_DB=openatlas

# Skip wasm/web rebuild on `up:fast`
# OPENATLAS_SKIP_BUILD=1

# LLM bridge → Ollama (set to 0 to skip on `up`)
OPENATLAS_START_LLM=1
OPENATLAS_OLLAMA_BASE=http://127.0.0.1:11434
OPENATLAS_OLLAMA_MODEL=llama3.2

# Optional ingest admin key (x-openatlas-key header)
# OPENATLAS_API_KEY=

# Feed API keys — prefer .dev/feed-secrets.json or Settings UI (see docs/CONFIG.md)
# OPENATLAS_FEED_SECRETS=.dev/feed-secrets.json
# FRED_API_KEY=
# EIA_API_KEY=

# Settings UI: minimum seconds between Test/Reconnect on the same feed (default 30)
# OPENATLAS_OPERATOR_FETCH_COOLDOWN_SECS=30

# Logging
# RUST_LOG=openatlas_ingest=info,info
