{
  "name": "openatlas-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "OpenAtlas dashboard — Svelte 5 + Vite + TypeScript. Use Bun: `bun install`, `bun run dev`, `bun run build`.",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "bun test src/lib"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/three": "^0.184.0",
    "svelte": "^5.1.9",
    "svelte-check": "^4.0.5",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "@lucide/svelte": "^1.8.0",
    "echarts": "^5.5.1",
    "globe.gl": "^2.45.3",
    "maplibre-gl": "^4.7.1",
    "satellite.js": "4.1.4",
    "spacetimedb": "2.1.0"
  }
}
