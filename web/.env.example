# Copy to web/.env (gitignored):  cp web/.env.example web/.env
# Vite exposes only VITE_* to the browser at build/dev time.
# See docs/CONFIG.md

# SpacetimeDB WebSocket (production / remote STDB). Local dev usually omits these
# (same host as the page, port 3000; see stdb-endpoint.ts).
# VITE_STDB_URI=ws://127.0.0.1:3000
# VITE_STDB_DB=openatlas

# Client-only demo mode (no SpacetimeDB). Prefer ?demo=1 or Settings instead.
# VITE_DEMO_DATA=1

# LLM bridge base URL (production). Dev uses Vite proxy /api/llm → :3847.
# VITE_LLM_BASE=https://your-host/api/llm
